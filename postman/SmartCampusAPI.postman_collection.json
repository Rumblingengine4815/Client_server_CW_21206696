{
  "info": {
    "_postman_id": "93fbab4f-08c9-48d1-9de8-f4f4e3ca9120",
    "name": "SmartCampusAPI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Discovery",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "Create Room",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"LIB-301\",\n  \"name\": \"Library Quiet Study\",\n  \"capacity\": 120\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rooms",
          "host": ["{{baseUrl}}"],
          "path": ["rooms"]
        }
      }
    },
    {
      "name": "Create Sensor",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"CO2-001\",\n  \"type\": \"CO2\",\n  \"status\": \"ACTIVE\",\n  \"roomId\": \"LIB-301\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sensors",
          "host": ["{{baseUrl}}"],
          "path": ["sensors"]
        }
      }
    },
    {
      "name": "Filter Sensors by Type",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/sensors?type=CO2",
          "host": ["{{baseUrl}}"],
          "path": ["sensors"],
          "query": [{"key": "type", "value": "CO2"}]
        }
      }
    },
    {
      "name": "Add Reading",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"value\": 540.7\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sensors/CO2-001/readings",
          "host": ["{{baseUrl}}"],
          "path": ["sensors", "CO2-001", "readings"]
        }
      }
    },
    {
      "name": "Get Readings",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/sensors/CO2-001/readings",
          "host": ["{{baseUrl}}"],
          "path": ["sensors", "CO2-001", "readings"]
        }
      }
    },
    {
      "name": "Delete Room Should Fail 409",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/rooms/LIB-301",
          "host": ["{{baseUrl}}"],
          "path": ["rooms", "LIB-301"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    }
  ]
}
